# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=agora
POSTGRES_PASSWORD=changeme
POSTGRES_DB=agora

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# CHROMA_PORT=8000 est le port interne Docker (ChromaDB écoute sur 8000 dans son conteneur).
# Le port 8888 est uniquement exposé vers l'hôte (8888:8000 dans docker-compose.yml).
# Pour la communication inter-services dans le réseau agora-network, utiliser chromadb:8000.
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=agora
MINIO_ROOT_PASSWORD=changeme
MINIO_BUCKET=agora-content

# ── JWT ───────────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
JWT_SECRET=changeme-generate-a-256-bit-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ── YouTube Data API v3 ───────────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── LLM & Embeddings — À définir lors de la phase ML ─────────────────────────
# LLM_PROVIDER=
# LLM_MODEL=
# EMBEDDING_MODEL=
# EMBEDDING_DIMENSION=
